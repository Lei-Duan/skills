#!/usr/bin/env bash
#
# Package a skill into a zip ready to upload to claude.ai
# (Settings → Capabilities → Skills).
# Usage: bin/package <category>/<skill-name>   e.g. bin/package personal/my-skill
#
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
target="${1:-}"

if [ -z "$target" ]; then
  echo "usage: bin/package <category>/<skill-name>"
  echo "example: bin/package personal/my-skill"
  exit 1
fi

skill_dir="$REPO/${target%/}"
if [ ! -f "$skill_dir/SKILL.md" ]; then
  echo "error: no SKILL.md found at $target" >&2
  exit 1
fi

name="$(basename "$skill_dir")"
parent="$(dirname "$skill_dir")"
out="$REPO/dist/$name.zip"

mkdir -p "$REPO/dist"
rm -f "$out"
( cd "$parent" && zip -r -q "$out" "$name" -x '*.DS_Store' )

echo "✓ packaged → dist/$name.zip"
echo "  upload at: claude.ai → Settings → Capabilities → Skills → Upload skill"
